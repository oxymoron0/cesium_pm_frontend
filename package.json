{
  "name": "pm-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build-pages && npm run copy-pages",
    "build-pages": "tsc -b && rm -rf dist temp-builds && mkdir -p temp-builds && for page in $(ls src/pages); do echo \"Building $page...\"; VITE_PAGE=$page vite build && cp dist/$page.umd.js temp-builds/; done && cp -r dist/* temp-builds/ && rm -rf dist && mv temp-builds dist",
    "copy-pages": "find src/pages -name 'index.html' -exec sh -c 'cp \"$1\" \"dist/$(basename $(dirname $1)).html\"' _ {} \\;",
    "create-page": "node create-page.js",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "cesium": "1.115.0",
    "mobx": "6.13.7",
    "mobx-react-lite": "4.1.0",
    "postcss-prefix-selector": "^2.1.1",
    "proj4": "^2.20.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "recharts": "^3.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/glob": "^9.0.0",
    "@types/proj4": "^2.19.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "glob": "^11.0.3",
    "globals": "^16.3.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vite-plugin-cesium": "^1.2.23"
  },
  "packageManager": "pnpm@10.15.1+sha512.34e538c329b5553014ca8e8f4535997f96180a1d0f614339357449935350d924e22f8614682191264ec33d1462ac21561aff97f6bb18065351c162c7e8f6de67"
}
